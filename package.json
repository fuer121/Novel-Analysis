{
  "name": "novel-chapter-gpt-service",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n server,client -c green,cyan \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "node --watch server/index.js",
    "dev:client": "vite --host 127.0.0.1",
    "start": "node server/index.js",
    "start:lan": "HOST=0.0.0.0 node server/index.js",
    "build": "vite build",
    "preview:prepare-data": "node scripts/prepare-preview-data.js",
    "build:preview": "vite build --outDir dist-preview",
    "start:preview": "APP_ENV=preview APP_LABEL=本机预览 HOST=127.0.0.1 PORT=5194 DATA_DIR=./data-preview STATIC_DIR=./dist-preview node server/index.js",
    "preview:local": "npm run preview:prepare-data && npm run build:preview && npm run start:preview",
    "lint": "eslint .",
    "preview": "vite preview --host 127.0.0.1",
    "dify:manifest": "node scripts/generate-dify-workflow-manifest.mjs",
    "dify:manifest:check": "node --test test/dify-workflow-manifest.test.js",
    "test": "node --test test/*.test.js",
    "test:contracts": "node --test test/contracts/*.test.js",
    "test:legacy": "node --test test/service.test.js",
    "test:new": "vitest run",
    "typecheck:new": "tsc -p packages/contracts/tsconfig.json && tsc -p packages/domain/tsconfig.json",
    "verify:new": "npm run typecheck:new && npm run test:contracts && npm run test:new",
    "lint:legacy": "eslint src server test/service.test.js",
    "build:legacy": "vite build",
    "verify:legacy": "npm run test:legacy && npm run lint:legacy && npm run build:legacy"
  },
  "dependencies": {
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "^7.0.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.10"
  }
}
